{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ollamakit-managed-relay",
  "main": "src/index.js",
  "compatibility_date": "2026-03-28",
  "durable_objects": {
    "bindings": [
      {
        "name": "DEVICE_RELAY_ROOM",
        "class_name": "DeviceRelayRoom"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": [
        "DeviceRelayRoom"
      ],
      "tag": "v1"
    }
  ]
}
